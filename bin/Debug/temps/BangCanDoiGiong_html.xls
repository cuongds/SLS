  <xsl:for-each select="NewDataSet/Table">
    <xsl:variable name="vSoPhieu" >
      <xsl:value-of select="Giao_MaPhieu"/>
    </xsl:variable>
    <tr>
      <xsl:if test="Giao_index &gt; 0">
       
       
        <xsl:variable name="vRowspan" >
          <xsl:choose>
            <xsl:when test="SoLuongPhieu &gt; 1">
